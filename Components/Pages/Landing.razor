@* Components/Pages/Landing.razor *@
@page "/"
@using TrustedGiving.Services
@inject NavigationManager Nav
@inject LanguageService LangService
@implements IDisposable

<div class="landing-container">
    <div class="landing-content">

        <img src="images/logo_large.png" style="width: 100%; max-width: 320px; object-fit: contain; margin-bottom: 16px;" />

        
        <div dir="@LangService.Direction" style="text-align: center;">
    
            <h2 class="landing-subtitle">
                @LangService.Get("ההשפעה שלך מתחילה כאן.", "Your impact starts here.")
            </h2>

            <p class="landing-description">
                @LangService.Get("נתינה חכמה מתחילה בשקיפות מלאה.", "Smart giving starts with full transparency.")<br />
                @LangService.Get("וודא שהתרומה שלך מגיעה למי שבאמת זקוק לה,", "Ensure your donation reaches those who truly need it,")<br />
                @LangService.Get("בעזרת נתונים מאומתים וביקורות מהשטח.", "using verified data and field reviews.")
            </p>
    
        </div>

        <div class="landing-stats">
            <div class="stat">
                <span class="stat-number">74K+</span>
                <span class="stat-label">@LangService.Get("עמותות", "Nonprofits")</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-number">100%</span>
                <span class="stat-label">@LangService.Get("שקיפות", "Transparency")</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
                <span class="stat-number">∞</span>
                <span class="stat-label">@LangService.Get("השפעה", "Impact")</span>
            </div>
        </div>

        <button class="cta-button" @onclick="GoToOrgs">
            @LangService.Get("מצא את העמותה שלך", "Find your nonprofit")
            <span class="cta-arrow">←</span>
        </button>

        <p class="landing-footer">@LangService.Get("מבוסס על נתוני רשם העמותות הרשמי", "Based on official nonprofit registry data")</p>
    </div>
</div>

@code {

    protected override void OnInitialized()
    {
        LangService.OnChange += StateHasChanged;
    }

    private void GoToOrgs()
    {
        Nav.NavigateTo("/orgs");
    }

    public void Dispose()
    {
        LangService.OnChange -= StateHasChanged;
    }
}