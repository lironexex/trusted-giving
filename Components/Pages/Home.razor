@* Components/Pages/Home.razor *@
@page "/orgs"
@inject AmutaService AmutaService
@inject LanguageService LangService
@implements IDisposable

<div style="padding: 16px; direction: @LangService.Direction">

    <MudText Typo="Typo.h5" Class="mb-2">
        @LangService.Get("עמותות ישראל", "Israeli Nonprofits")
    </MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-4" Style="opacity: 0.7">
        @LangService.Get("מצא עמותות ותרום למטרות שחשובות לך", "Find nonprofits and donate to causes that matter")
    </MudText>

    <MudTextField @bind-Value="searchQuery"
                  Placeholder="@LangService.Get("חפש עמותה...", "Search nonprofit...")"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Class="mb-4"
                  DebounceInterval="500"
                  OnDebounceIntervalElapsed="OnSearch" />

    @* Category filter chips — each maps a display label to the Hebrew API value *@
    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px;">
        @foreach (var filter in categoryFilters)
        {
            var isActive = selectedCategory == filter.ApiValue;
            <MudChip T="string"
                     Color="@(isActive ? Color.Primary : Color.Default)"
                     Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                     Size="Size.Medium"
                     OnClick="() => OnCategorySelected(filter.ApiValue)"
                     Style="cursor: pointer;">
                @filter.Icon @LangService.Get(filter.LabelHebrew, filter.LabelEnglish)
            </MudChip>
        }
    </div>

    @if (isLoading)
    {
        <div style="display: flex; justify-content: center; padding: 48px">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (amutot.Count == 0)
    {
        <MudText Align="Align.Center" Style="opacity: 0.5; padding: 48px">
            @LangService.Get("לא נמצאו עמותות", "No nonprofits found")
        </MudText>
    }
    else
    {
        <MudGrid>
            @foreach (var amuta in amutot)
            {
                <MudItem xs="12">
                    <MudCard Elevation="2" Style="cursor: pointer" @onclick="() => SelectAmuta(amuta)">
                        <MudCardContent>
                            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 8px">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1">
                                    @amuta.NameHebrew
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
                                    @amuta.ActivityCategory
                                </MudChip>
                            </div>
                            <div style="display: flex; gap: 16px; margin-top: 8px; opacity: 0.7">
                                <MudText Typo="Typo.body2">📍 @amuta.City</MudText>
                                @if (amuta.VolunteerCount.HasValue)
                                {
                                    <MudText Typo="Typo.body2">🙋 @amuta.VolunteerCount @LangService.Get("מתנדבים", "volunteers")</MudText>
                                }
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <div style="display: flex; justify-content: center; align-items: center; gap: 16px; margin-top: 24px; padding: 16px">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                           Disabled="@(currentPage == 0)"
                           OnClick="PrevPage"
                           Color="Color.Primary" />
            <MudText>@LangService.Get("עמוד", "Page") @(currentPage + 1)</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NextPage"
                           Color="Color.Primary" />
        </div>
    }
</div>

@code {
    // Represents a single category filter button
    private record CategoryFilter(string LabelHebrew, string LabelEnglish, string ApiValue, string Icon);

    // Well-known mappings from Hebrew API values to friendly English labels and emojis.
    // Any category returned by the API that isn't listed here will still appear,
    // using its raw Hebrew value as both labels and a generic icon.
    private static readonly Dictionary<string, (string English, string Icon)> KnownCategories = new()
    {
        ["דת"] = ("Religion", "🕍"),
        ["ארגוני סנגור~ שינוי חברתי פוליטי"] = ("Advocacy", "✊"),
        ["בריאות או הצלת חיים"] = ("Health", "❤️‍🩹"),
        ["חינוך~ השכלה והכשרה מקצועית"] = ("Education", "📚"),
        ["מורשת או הנצחה"] = ("Heritage", "🏛️"),
        ["מחקר~ מדע וטכנולוגיה"] = ("Science", "🔬"),
        ["קהילה וחברה"] = ("Community", "🏘️"),
        ["קשרים בינלאומיים"] = ("International", "🌍"),
        ["שיכון ופיתוח עירוני"] = ("Urban Dev", "🏗️"),
        ["שירותי רווחה"] = ("Welfare", "🤝"),
        ["ספורט"] = ("Sports", "⚽"),
        ["סביבה ובעלי חיים"] = ("Environment", "🌿"),
        ["תרבות או אמנות"] = ("Culture", "🎭"),
    };

    // Built at runtime from actual API values; starts with the "All" entry
    private List<CategoryFilter> categoryFilters = new() { new("הכל", "All", "", "🌐") };

    private List<Amuta> amutot = new();
    private bool isLoading = true;
    private string searchQuery = "";
    private string selectedCategory = "";
    private int currentPage = 0;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        // Load real category values from the API first, then fetch the first page of results
        await LoadCategoriesAsync();
        await LoadAmutot();
    }

    // Fetches distinct סיווג פעילות ענפי values from the API and builds the filter chip list
    private async Task LoadCategoriesAsync()
    {
        var apiValues = await AmutaService.GetCategoriesAsync();

        categoryFilters = new List<CategoryFilter> { new("הכל", "All", "", "🌐") };
        categoryFilters.AddRange(apiValues.Select(v =>
        {
            // Try exact match first, then fall back to prefix match (handles spacing/encoding variants)
            if (!KnownCategories.TryGetValue(v, out var known))
                known = KnownCategories.FirstOrDefault(kv => v.StartsWith(kv.Key.Split('~')[0].Trim())).Value;

            var (english, icon) = known != default ? known : (v, "📌");
            return new CategoryFilter(v, english, v, icon);
        }));
    }

    // Loads amutot from the service, passing the active search query and category filter.
    private async Task LoadAmutot()
    {
        isLoading = true;
        amutot = await AmutaService.GetAmutotAsync(PageSize * 3, currentPage * PageSize * 3, searchQuery, selectedCategory);
        isLoading = false;
    }

    // Resets to page 0 and reloads when the search query changes.
    private async Task OnSearch()
    {
        currentPage = 0;
        await LoadAmutot();
    }

    // Toggles the selected category: clicking an active category deselects it (shows all).
    private async Task OnCategorySelected(string apiValue)
    {
        selectedCategory = selectedCategory == apiValue ? "" : apiValue;
        currentPage = 0;
        await LoadAmutot();
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadAmutot();
    }

    private async Task PrevPage()
    {
        if (currentPage > 0)
        {
            currentPage--;
            await LoadAmutot();
        }
    }

    private void SelectAmuta(Amuta amuta)
    {
        // Navigate to detail page later
    }

    protected override void OnInitialized()
    {
        LangService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        LangService.OnChange -= StateHasChanged;
    }
}
